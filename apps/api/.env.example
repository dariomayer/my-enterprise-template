# Environment
NODE_ENV=development
PORT=3000

# Database (PostgreSQL default — see ai-context/database-strategy.md to switch engine)
DATABASE_URL="postgresql://postgres:password@localhost:5432/enterprise_dev?schema=public"

# Authentication — REQUIRED, must be at least 32 characters
JWT_SECRET="replace_with_a_cryptographically_strong_secret_at_least_32_chars"

# CORS — comma-separated list of allowed origins (whitelist)
CORS_ORIGIN="http://localhost:5173"
